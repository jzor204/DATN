APP_NAME=task-management
APP_ENV=production
APP_PORT=8080

DB_DRIVER=mysql
DATABASE_URL=

MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=task_user
MYSQL_PASSWORD=change-this-task-password
MYSQL_DATABASE=task_management

REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=change-this-to-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24

BOOTSTRAP_ADMIN_NAME=Admin User
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=

# Use your VPS IP for IP-only deploy, for example: 172.23.32.1
# Use your domain when you have one, for example: task.example.com
SWAGGER_HOST=your-server-ip-or-domain
SWAGGER_SCHEMES=http

# Render free deploy path uses Postgres/Key Value instead of MySQL.
# In Render, set DB_DRIVER=postgres, DATABASE_URL from Render Postgres,
# REDIS_URL from Render Key Value, and leave MYSQL_* unused.
